# =========================================================================
# CATALYST: PROJECT ENVIRONMENT CONFIGURATION
# =========================================================================
# Copy this file to '.env' and fill in your private API keys.
# Maintain this file for onboarding and consistency across environments.

# -------------------------------------------------------------------------
# 1. EXTERNAL API KEYS (REQUIRED)
# -------------------------------------------------------------------------
# Google Gemini (Brain/Triage)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash

# Financial Modeling Prep (Drifter Hunter/Earnings)
FMP_API_KEY=

# Alpaca (Java Strategist Engine - Execution)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_IS_PAPER=true

# -------------------------------------------------------------------------
# 2. INFRASTRUCTURE (NETWORKING)
# -------------------------------------------------------------------------
# Kafka Settings
# Use 'kafka:29092' for internal docker-to-docker communication
# Use 'localhost:9092' for local microservices running outside Docker
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Redis Settings (Gatekeeper State & Biotech Calendar)
REDIS_HOST=localhost
REDIS_PORT=6379

# PostgreSQL / TimescaleDB (Strategy Storage)
POSTGRES_USER=catalyst_user
POSTGRES_PASSWORD=password123
POSTGRES_DB=catalyst_db

# -------------------------------------------------------------------------
# 3. KAFKA TOPICS & CONSUMER GROUPS (THE NERVOUS SYSTEM)
# -------------------------------------------------------------------------
# Core Pipeline Topics
RAW_EVENTS_TOPIC=raw-events
TRIAGE_PRIORITY_TOPIC=triage-priority
VALIDATED_SIGNALS_TOPIC=validated-signals
TRADE_ORDERS_TOPIC=trade-orders

# Hunter-Specific Signal Topics
KAFKA_TOPIC_SQUEEZE=signal-squeeze
KAFKA_TOPIC_INSIDER=signal-insider
KAFKA_TOPIC_WHALE=signal-whale
KAFKA_TOPIC_BIOTECH=signal-biotech
KAFKA_TOPIC_DRIFTER=signal-earnings
KAFKA_TOPIC_SHADOW=signal-shadow

# Consumer Groups
GATEKEEPER_CONSUMER_GROUP=gatekeeper-service
AI_LAYER_CONSUMER_GROUP=ai-analysis-service
STRATEGY_ENGINE_CONSUMER_GROUP=strategy-engine

# Offset Behavior (earliest/latest)
GATEKEEPER_AUTO_OFFSET_RESET=earliest
AI_LAYER_AUTO_OFFSET_RESET=earliest

# -------------------------------------------------------------------------
# 4. GATEKEEPER TRIAGE THRESHOLDS (LAYER 2.5)
# -------------------------------------------------------------------------
# Rolling window in seconds for signal aggregation
GATEKEEPER_ROLLING_WINDOW_SECONDS=300

# Minimum Hardware Filters
GATEKEEPER_MIN_VOLUME=50000
GATEKEEPER_MIN_RELATIVE_VOLUME=1.5

# Trigger Logic
GATEKEEPER_CONFLUENCE_THRESHOLD=2
GATEKEEPER_TECHNICAL_SCORE_THRESHOLD=70

# -------------------------------------------------------------------------
# 5. AI LAYER SETTINGS (LAYER 3)
# -------------------------------------------------------------------------
# AI Decision parameters
GEMINI_TEMPERATURE=0.2
GEMINI_MAX_RETRIES=3
GEMINI_INITIAL_BACKOFF_SECONDS=1
AI_MIN_CONVICTION_SCORE=50

# -------------------------------------------------------------------------
# 6. HUNTERS & SCRAPERS (LAYER 1)
# -------------------------------------------------------------------------
# Playwright settings for browser-based hunters (Whale, Biotech, Shadow)
HEADLESS_MODE=True

# -------------------------------------------------------------------------
# 7. LOGGING & DEBUGGING
# -------------------------------------------------------------------------
# Levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
